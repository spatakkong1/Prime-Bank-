    <div id="reviewTransferModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 animate-fade-in">
            <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">Review Transfer</h3>
            
            <div class="space-y-4 mb-6">
                <div class="flex justify-between py-2 border-b border-gray-100">
                    <span class="text-gray-600">From</span>
                    <span class="font-medium" id="reviewFrom">Account</span>
                </div>
                <div class="flex justify-between py-2 border-b border-gray-100">
                    <span class="text-gray-600">To</span>
                    <span class="font-medium" id="reviewTo">Account</span>
                </div>
                <div class="flex justify-between py-2 border-b border-gray-100">
                    <span class="text-gray-600">Amount</span>
                    <span class="font-bold text-xl text-gray-900" id="reviewAmount">$0.00</span>
                </div>
                <div class="flex justify-between py-2 border-b border-gray-100">
                    <span class="text-gray-600">When</span>
                    <span class="font-medium" id="reviewWhen">Today</span>
                </div>
                <div class="flex justify-between py-2">
                    <span class="text-gray-600">Memo</span>
                    <span class="font-medium" id="reviewMemo">-</span>
                </div>
            </div>
            
            <div class="space-y-2">
                <button onclick="confirmTransfer()" class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-lg">
                    Confirm Transfer
                </button>
                <button onclick="closeModal('reviewTransferModal')" class="w-full bg-gray-200 text-gray-700 py-3 rounded-lg font-semibold hover:bg-gray-300 transition">
                    Cancel
                </button>
            </div>
        </div>
    </div>

    <script>
        // Banking Application State
        let currentUser = null;
        let chartInstance = null;
        let pendingTransfer = null;

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            checkExistingSession();
            setupEventListeners();
            
            // Set default transfer date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('transferDate').value = today;
            document.getElementById('paymentDate').value = today;
        });

        function checkExistingSession() {
            const saved = localStorage.getItem('fnb_current_user');
            const session = sessionStorage.getItem('fnb_session');
            
            if (saved && session) {
                currentUser = JSON.parse(saved);
                showMainApp();
            }
        }

        function setupEventListeners() {
            // Transfer when radio buttons
            document.querySelectorAll('input[name="transferWhen"]').forEach(radio => {
                radio.addEventListener('change', function() {
                    const dateDiv = document.getElementById('scheduleDate');
                    dateDiv.classList.toggle('hidden', this.value !== 'later');
                });
            });
        }

        // Authentication Functions
        function showEnroll() {
            document.getElementById('loginForm').classList.add('hidden');
            document.getElementById('enrollForm').classList.remove('hidden');
            document.getElementById('forgotForm').classList.add('hidden');
        }

        function showLogin() {
            document.getElementById('loginForm').classList.remove('hidden');
            document.getElementById('enrollForm').classList.add('hidden');
            document.getElementById('forgotForm').classList.add('hidden');
        }

        function showForgotPassword() {
            document.getElementById('loginForm').classList.add('hidden');
            document.getElementById('forgotForm').classList.remove('hidden');
        }

        function handleLogin(e) {
            e.preventDefault();
            const userId = document.getElementById('loginUserId').value;
            const password = document.getElementById('loginPassword').value;
            
            // Show spinner
            document.getElementById('loginSpinner').classList.remove('hidden');
            
            setTimeout(() => {
                const users = JSON.parse(localStorage.getItem('fnb_users') || '[]');
                const user = users.find(u => u.userId === userId && u.password === password);
                
                if (user) {
                    currentUser = user;
                    currentUser.lastLogin = new Date().toLocaleString();
                    
                    if (document.getElementById('rememberMe').checked) {
                        localStorage.setItem('fnb_current_user', JSON.stringify(currentUser));
                    }
                    sessionStorage.setItem('fnb_session', 'active');
                    
                    showToast('Welcome back, ' + user.firstName + '!', 'success');
                    showMainApp();
                } else {
                    showToast('Invalid User ID or Password', 'error');
                }
                
                document.getElementById('loginSpinner').classList.add('hidden');
            }, 1000);
        }

        function handleEnroll(e) {
            e.preventDefault();
            
            const password = document.getElementById('enrollPassword').value;
            const confirmPassword = document.getElementById('enrollConfirmPassword').value;
            
            if (password !== confirmPassword) {
                showToast('Passwords do not match', 'error');
                return;
            }
            
            if (!validatePassword(password)) {
                showToast('Password must contain uppercase, number, and special character', 'error');
                return;
            }
            
            document.getElementById('enrollSpinner').classList.remove('hidden');
            
            setTimeout(() => {
                const users = JSON.parse(localStorage.getItem('fnb_users') || '[]');
                const newUserId = document.getElementById('enrollUserId').value;
                
                if (users.find(u => u.userId === newUserId)) {
                    showToast('User ID already exists', 'error');
                    document.getElementById('enrollSpinner').classList.add('hidden');
                    return;
                }
                
                const initialDeposit = parseFloat(document.getElementById('enrollDeposit').value) || 1000;
                
                const newUser = {
                    id: Date.now(),
                    userId: newUserId,
                    password: password,
                    firstName: document.getElementById('enrollFirstName').value,
                    lastName: document.getElementById('enrollLastName').value,
                    email: document.getElementById('enrollEmail').value,
                    phone: document.getElementById('enrollPhone').value,
                    address: '',
                    createdAt: new Date().toISOString(),
                    lastLogin: new Date().toLocaleString(),
                    accounts: {
                        checking: {
                            number: '4521',
                            balance: initialDeposit,
                            available: initialDeposit
                        },
                        savings: {
                            number: '7894',
                            balance: 0,
                            interest: 0
                        },
                        card: {
                            number: '8842',
                            balance: 0,
                            limit: 10000,
                            available: 10000,
                            dueDate: getNextMonthDate(),
                            cashback: 0
                        }
                    },
                    transactions: generateInitialTransactions(initialDeposit),
                    payees: [
                        { id: 1, name: 'Electric Company', account: 'ELEC-001', amount: 134.00, autopay: true },
                        { id: 2, name: 'Internet Provider', account: 'NET-001', amount: 79.99, autopay: true },
                        { id: 3, name: 'Mortgage Company', account: 'MORT-001', amount: 2100.00, autopay: false }
                    ],
                    payments: []
                };
                
                users.push(newUser);
                localStorage.setItem('fnb_users', JSON.stringify(users));
                
                currentUser = newUser;
                localStorage.setItem('fnb_current_user', JSON.stringify(currentUser));
                sessionStorage.setItem('fnb_session', 'active');
                
                showToast('Account created successfully!', 'success');
                showMainApp();
            }, 1500);
        }

        function validatePassword(password) {
            return /^(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/.test(password);
        }

        function getNextMonthDate() {
            const date = new Date();
            date.setMonth(date.getMonth() + 1);
            return date.toISOString().split('T')[0];
        }

        function generateInitialTransactions(initialDeposit) {
            const transactions = [];
            const categories = ['Deposit', 'Transfer', 'Payment', 'Purchase', 'Refund'];
            const descriptions = ['Initial Deposit', 'Payroll Deposit', 'Electric Bill', 'Grocery Store', 'Online Purchase', 'Refund'];
            
            // Add initial deposit
            transactions.push({
                id: Date.now(),
                date: new Date().toISOString(),
                description: 'Account Opening Deposit',
                category: 'Deposit',
                account: 'checking',
                amount: initialDeposit,
                type: 'credit'
            });
            
            // Generate some random history
            for (let i = 1; i <= 10; i++) {
                const daysAgo = i * 3;
                const date = new Date();
                date.setDate(date.getDate() - daysAgo);
                
                const isCredit = Math.random() > 0.6;
                const amount = (Math.random() * 500 + 50).toFixed(2);
                
                transactions.push({
                    id: Date.now() + i,
                    date: date.toISOString(),
                    description: descriptions[Math.floor(Math.random() * descriptions.length)],
                    category: categories[Math.floor(Math.random() * categories.length)],
                    account: ['checking', 'savings', 'card'][Math.floor(Math.random() * 3)],
                    amount: parseFloat(amount),
                    type: isCredit ? 'credit' : 'debit'
                });
            }
            
            return transactions.sort((a, b) => new Date(b.date) - new Date(a.date));
        }

        function handleForgotPassword(e) {
            e.preventDefault();
            showToast('Password reset link sent to your email', 'success');
            showLogin();
        }

        function logout() {
            localStorage.removeItem('fnb_current_user');
            sessionStorage.removeItem('fnb_session');
            currentUser = null;
            location.reload();
        }

        // Main App Functions
        function showMainApp() {
            document.getElementById('authScreen').classList.add('hidden');
            document.getElementById('mainApp').classList.remove('hidden');
            document.getElementById('mainApp').classList.add('animate-fade-in');
            
            updateUserDisplay();
            updateBalances();
            loadTransactions();
            loadPayees();
            initChart();
        }

        function updateUserDisplay() {
            document.getElementById('userNameDisplay').textContent = currentUser.firstName + ' ' + currentUser.lastName;
            document.getElementById('welcomeMessage').textContent = 'Welcome back, ' + currentUser.firstName;
            document.getElementById('lastLogin').textContent = currentUser.lastLogin || 'Today';
            
            // Profile form
            document.getElementById('profileFirstName').value = currentUser.firstName;
            document.getElementById('profileLastName').value = currentUser.lastName;
            document.getElementById('profileEmail').value = currentUser.email;
            document.getElementById('profilePhone').value = currentUser.phone || '';
            document.getElementById('profileAddress').value = currentUser.address || '';
            
            // Card display
            document.getElementById('displayCardName').textContent = (currentUser.firstName + ' ' + currentUser.lastName).toUpperCase();
            document.getElementById('displayCardNumber').textContent = '**** **** **** ' + currentUser.accounts.card.number;
        }

        function updateBalances() {
            const acc = currentUser.accounts;
            
            // Checking
            document.getElementById('checkingBalance').textContent = formatCurrency(acc.checking.balance);
            document.getElementById('checkingAvailable').textContent = 'Available: ' + formatCurrency(acc.checking.available);
            document.getElementById('checkingNumber').textContent = '****' + acc.checking.number;
            
            // Savings
            document.getElementById('savingsBalance').textContent = formatCurrency(acc.savings.balance);
            document.getElementById('savingsInterest').textContent = formatCurrency(acc.savings.interest);
            document.getElementById('savingsNumber').textContent = '****' + acc.savings.number;
            
            // Card
            document.getElementById('cardBalance').textContent = formatCurrency(acc.card.balance);
            document.getElementById('cardNumber').textContent = '****' + acc.card.number;
            document.getElementById('ccBalance').textContent = formatCurrency(acc.card.balance);
            document.getElementById('ccAvailable').textContent = formatCurrency(acc.card.available);
            document.getElementById('ccCashback').textContent = formatCurrency(acc.card.cashback);
            
            // Calculate minimum payment (2% or $25, whichever is greater)
            const minPayment = Math.max(acc.card.balance * 0.02, 25);
            document.getElementById('ccMinimum').textContent = acc.card.balance > 0 ? formatCurrency(minPayment) : '$0.00';
            
            // Update transfer dropdowns
            updateTransferOptions();
        }

        function formatCurrency(amount) {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD'
            }).format(amount);
        }

        function loadTransactions(limit = 5) {
            const container = document.getElementById('recentTransactions');
            const tableBody = document.getElementById('transactionsTable');
            
            container.innerHTML = '';
            tableBody.innerHTML = '';
            
            const sorted = currentUser.transactions.slice(0, limit === 'all' ? undefined : limit);
            
            sorted.forEach(t => {
                // Dashboard list
                const icon = getCategoryIcon(t.category);
                const colorClass = t.type === 'credit' ? 'text-green-600' : 'text-gray-900';
                const sign = t.type === 'credit' ? '+' : '-';
                
                const html = `
                    <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition cursor-pointer" onclick="showTransactionDetail(${t.id})">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 ${icon.bg} rounded-full flex items-center justify-center flex-shrink-0">
                                <i class="${icon.icon} ${icon.color} text-sm"></i>
                            </div>
                            <div class="min-w-0">
                                <p class="font-medium text-gray-900 truncate">${t.description}</p>
                                <p class="text-xs text-gray-500">${formatDate(t.date)}</p>
                            </div>
                        </div>
                        <span class="font-semibold ${colorClass} flex-shrink-0">${sign}${formatCurrency(t.amount)}</span>
                    </div>
                `;
                container.innerHTML += html;
                
                // Table row
                const row = `
                    <tr class="hover:bg-gray-50 cursor-pointer" onclick="showTransactionDetail(${t.id})">
                        <td class="px-4 py-3 text-sm">${formatDate(t.date)}</td>
                        <td class="px-4 py-3 font-medium">${t.description}</td>
                        <td class="px-4 py-3 text-sm"><span class="px-2 py-1 bg-gray-100 rounded-full text-xs">${t.category}</span></td>
                        <td class="px-4 py-3 text-sm capitalize">${t.account}</td>
                        <td class="px-4 py-3 text-right font-semibold ${colorClass}">${sign}${formatCurrency(t.amount)}</td>
                    </tr>
                `;
                tableBody.innerHTML += row;
            });
        }

        function getCategoryIcon(category) {
            const icons = {
                'Deposit': { icon: 'fas fa-arrow-down', bg: 'bg-green-100', color: 'text-green-600' },
                'Transfer': { icon: 'fas fa-exchange-alt', bg: 'bg-blue-100', color: 'text-blue-600' },
                'Payment': { icon: 'fas fa-file-invoice-dollar', bg: 'bg-red-100', color: 'text-red-600' },
                'Purchase': { icon: 'fas fa-shopping-bag', bg: 'bg-purple-100', color: 'text-purple-600' },
                'Refund': { icon: 'fas fa-undo', bg: 'bg-yellow-100', color: 'text-yellow-600' },
                'Food': { icon: 'fas fa-utensils', bg: 'bg-orange-100', color: 'text-orange-600' },
                'Transport': { icon: 'fas fa-car', bg: 'bg-gray-100', color: 'text-gray-600' }
            };
            return icons[category] || { icon: 'fas fa-circle', bg: 'bg-gray-100', color: 'text-gray-600' };
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        // Navigation
        function showSection(section) {
            // Hide all sections
            ['dashboard', 'accounts', 'transfer', 'pay', 'cards', 'profile'].forEach(s => {
                document.getElementById(s + 'Section').classList.add('hidden');
                const nav = document.getElementById('nav-' + s);
                if (nav) nav.classList.remove('active');
            });
            
            // Show selected
            document.getElementById(section + 'Section').classList.remove('hidden');
            const nav = document.getElementById('nav-' + section);
            if (nav) nav.classList.add('active');
            
            // Special handling
            if (section === 'accounts') loadTransactions('all');
            if (section === 'pay') loadPayees();
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleUserMenu() {
            document.getElementById('userDropdown').classList.toggle('hidden');
        }

        // Transfer Functions
        function updateTransferOptions() {
            const fromSelect = document.getElementById('transferFrom');
            const toSelect = document.getElementById('transferTo');
            
            fromSelect.innerHTML = `
                <option value="checking">Platinum Checking (...${currentUser.accounts.checking.number}) - ${formatCurrency(currentUser.accounts.checking.balance)}</option>
                <option value="savings">High Yield Savings (...${currentUser.accounts.savings.number}) - ${formatCurrency(currentUser.accounts.savings.balance)}</option>
            `;
            
            updateTransferTo();
        }

        function updateTransferTo() {
            const from = document.getElementById('transferFrom').value;
            const toSelect = document.getElementById('transferTo');
            const available = currentUser.accounts[from].balance;
            
            document.getElementById('transferAvailable').textContent = formatCurrency(available);
            
            toSelect.innerHTML = '';
            if (from !== 'checking') {
                toSelect.innerHTML += `<option value="checking">Platinum Checking (...${currentUser.accounts.checking.number})</option>`;
            }
            if (from !== 'savings') {
                toSelect.innerHTML += `<option value="savings">High Yield Savings (...${currentUser.accounts.savings.number})</option>`;
            }
            toSelect.innerHTML += `<option value="external">External Account (...4455)</option>`;
        }

        function handleTransfer(e) {
            e.preventDefault();
            const amount = parseFloat(document.getElementById('transferAmount').value);
            const from = document.getElementById('transferFrom').value;
            const to = document.getElementById('transferTo').value;
            const memo = document.getElementById('transferMemo').value;
            const when = document.querySelector('input[name="transferWhen"]:checked').value;
            
            if (!amount || amount <= 0) {
                showToast('Please enter a valid amount', 'error');
                return;
            }
            
            if (amount > currentUser.accounts[from].balance) {
                showToast('Insufficient funds', 'error');
                return;
            }
            
            pendingTransfer = { amount, from, to, memo, when };
            
            document.getElementById('reviewFrom').textContent = from === 'checking' ? 'Platinum Checking' : 'High Yield Savings';
            document.getElementById('reviewTo').textContent = to === 'external' ? 'External Account (...4455)' : (to === 'checking' ? 'Platinum Checking' : 'High Yield Savings');
            document.getElementById('reviewAmount').textContent = formatCurrency(amount);
            document.getElementById('reviewWhen').textContent = when === 'now' ? 'Today' : document.getElementById('transferDate').value;
            document.getElementById('reviewMemo').textContent = memo || '-';
            
            document.getElementById('reviewTransferModal').classList.remove('hidden');
        }

        function confirmTransfer() {
            if (!pendingTransfer) return;
            
            const { amount, from, to, memo, when } = pendingTransfer;
            
            // Deduct from source
            currentUser.accounts[from].balance -= amount;
            currentUser.accounts[from].available -= amount;
            
            // Add to destination (if internal)
            if (to !== 'external') {
                currentUser.accounts[to].balance += amount;
                if (to === 'checking') currentUser.accounts[to].available += amount;
            }
            
            // Add transaction
            currentUser.transactions.unshift({
                id: Date.now(),
                date: new Date().toISOString(),
                description: 'Transfer to ' + (to === 'external' ? 'External' : to.charAt(0).toUpperCase() + to.slice(1)),
                category: 'Transfer',
                account: from,
                amount: amount,
                type: 'debit',
                memo: memo
            });
            
            if (to !== 'external') {
                currentUser.transactions.unshift({
                    id: Date.now() + 1,
                    date: new Date().toISOString(),
                    description: 'Transfer from ' + (from === 'checking' ? 'Checking' : 'Savings'),
                    category: 'Transfer',
                    account: to,
                    amount: amount,
                    type: 'credit',
                    memo: memo
                });
            }
            
            saveUser();
            updateBalances();
            loadTransactions();
            
            closeModal('reviewTransferModal');
            showToast('Transfer completed successfully', 'success');
            
            pendingTransfer = null;
            document.getElementById('transferAmount').value = '';
            document.getElementById('transferMemo').value = '';
        }

        // Deposit Functions
        function showDepositModal() {
            document.getElementById('depositModal').classList.remove('hidden');
        }

        function handleDeposit(e) {
            e.preventDefault();
            const account = document.getElementById('depositAccount').value;
            const amount = parseFloat(document.getElementById('depositAmount').value);
            
            if (!amount || amount <= 0) {
                showToast('Please enter a valid amount', 'error');
                return;
            }
            
            // Simulate processing delay
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<div class="loading-spinner mx-auto"></div>';
            btn.disabled = true;
            
            setTimeout(() => {
                currentUser.accounts[account].balance += amount;
                if (account === 'checking') currentUser.accounts[account].available += amount;
                
                currentUser.transactions.unshift({
                    id: Date.now(),
                    date: new Date().toISOString(),
                    description: 'Mobile Check Deposit',
                    category: 'Deposit',
                    account: account,
                    amount: amount,
                    type: 'credit'
                });
                
                saveUser();
                updateBalances();
                loadTransactions();
                
                closeModal('depositModal');
                showToast('Deposit submitted for processing', 'success');
                
                btn.innerHTML = originalText;
                btn.disabled = false;
                e.target.reset();
            }, 2000);
        }

        // Payee Functions
        function loadPayees() {
            const container = document.getElementById('payeesList');
            const historyContainer = document.getElementById('paymentHistory');
            
            container.innerHTML = '';
            historyContainer.innerHTML = '';
            
            let dueCount = 0;
            let totalDue = 0;
            let autopayCount = 0;
            
            currentUser.payees.forEach(payee => {
                if (payee.autopay) autopayCount++;
                dueCount++;
                totalDue += payee.amount;
                
                const html = `
                    <div class="flex items-center justify-between p-4 border border-gray-200 rounded-xl hover:border-blue-300 transition">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                                <i class="fas fa-building text-blue-600"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-gray-900">${payee.name}</p>
                                <p class="text-sm text-gray-500">Acct: ...${payee.account.slice(-4)}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="font-bold text-gray-900">${formatCurrency(payee.amount)}</p>
                            <p class="text-xs ${payee.autopay ? 'text-green-600' : 'text-gray-500'}">
                                ${payee.autopay ? '<i class="fas fa-check-circle mr-1"></i>Auto-pay' : 'Manual'}
                            </p>
                            <button onclick="showPaymentModal(${payee.id})" class="mt-2 px-3 py-1 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">Pay</button>
                        </div>
                    </div>
                `;
                container.innerHTML += html;
            });
            
            // Payment history
            currentUser.payments.slice(0, 5).forEach(p => {
                historyContainer.innerHTML += `
                    <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg">
                        <div>
                            <p class="font-medium text-gray-900">${p.payeeName}</p>
                            <p class="text-xs text-gray-500">${formatDate(p.date)}</p>
                        </div>
                        <span class="font-semibold text-gray-900">${formatCurrency(p.amount)}</span>
                    </div>
                `;
            });
            
            document.getElementById('billsDueCount').textContent = dueCount;
            document.getElementById('totalDueAmount').textContent = formatCurrency(totalDue);
            document.getElementById('autopayCount').textContent = autopayCount + ' bills';
        }

        function showAddPayeeModal() {
            document.getElementById('addPayeeModal').classList.remove('hidden');
        }

        function handleAddPayee(e) {
            e.preventDefault();
            
            const newPayee = {
                id: Date.now(),
                name: document.getElementById('payeeName').value,
                account: document.getElementById('payeeAccount').value,
                address: document.getElementById('payeeAddress').value,
                amount: parseFloat(document.getElementById('payeeAmount').value) || 0,
                autopay: false
            };
            
            currentUser.payees.push(newPayee);
            saveUser();
            loadPayees();
            closeModal('addPayeeModal');
            showToast('Payee added successfully', 'success');
            e.target.reset();
        }

        function showPaymentModal(payeeId) {
            const payee = currentUser.payees.find(p => p.id === payeeId);
            if (!payee) return;
            
            document.getElementById('paymentPayeeId').value = payeeId;
            document.getElementById('paymentPayeeName').textContent = payee.name;
            document.getElementById('paymentAmount').value = payee.amount.toFixed(2);
            document.getElementById('paymentModal').classList.remove('hidden');
        }

        function handlePayment(e) {
            e.preventDefault();
            const payeeId = parseInt(document.getElementById('paymentPayeeId').value);
            const amount = parseFloat(document.getElementById('paymentAmount').value);
            const from = document.getElementById('paymentFrom').value;
            
            if (amount > currentUser.accounts[from].balance) {
                showToast('Insufficient funds', 'error');
                return;
            }
            
            currentUser.accounts[from].balance -= amount;
            currentUser.accounts[from].available -= amount;
            
            const payee = currentUser.payees.find(p => p.id === payeeId);
            
            currentUser.payments.unshift({
                id: Date.now(),
                payeeId: payeeId,
                payeeName: payee.name,
                amount: amount,
                date: new Date().toISOString(),
                from: from
            });
            
            currentUser.transactions.unshift({
                id: Date.now(),
                date: new Date().toISOString(),
                description: 'Payment to ' + payee.name,
                category: 'Payment',
                account: from,
                amount: amount,
                type: 'debit'
            });
            
            saveUser();
            updateBalances();
            loadTransactions();
            loadPayees();
            
            closeModal('paymentModal');
            showToast('Payment scheduled successfully', 'success');
        }

        // Card Functions
        function toggleCardLock() {
            const isLocked = document.getElementById('lockCard').checked;
            showToast(isLocked ? 'Card locked successfully' : 'Card unlocked', isLocked ? 'warning' : 'success');
        }

        function showCardNumber() {
            const fullNumber = '4532 1234 5678 ' + currentUser.accounts.card.number;
            showToast('Card Number: ' + fullNumber, 'info', 5000);
        }

        function requestNewCard() {
            showToast('New card request submitted. Expected delivery: 5-7 business days.', 'success');
        }

        function disputeCharge() {
            showToast('Please call customer service at 1-800-FNB-HELP to dispute charges', 'info');
        }

        function reportLost() {
            if (confirm('Are you sure you want to report this card lost/stolen? This will permanently lock the card.')) {
                document.getElementById('lockCard').checked = true;
                showToast('Card reported lost. New card being issued.', 'warning');
            }
        }

        // Profile Functions
        function updateProfile(e) {
            e.preventDefault();
            
            currentUser.firstName = document.getElementById('profileFirstName').value;
            currentUser.lastName = document.getElementById('profileLastName').value;
            currentUser.email = document.getElementById('profileEmail').value;
            currentUser.phone = document.getElementById('profilePhone').value;
            currentUser.address = document.getElementById('profileAddress').value;
            
            saveUser();
            updateUserDisplay();
            showToast('Profile updated successfully', 'success');
        }

        // Chart Functions
        function initChart() {
            const ctx = document.getElementById('spendingChart').getContext('2d');
            
            if (chartInstance) {
                chartInstance.destroy();
            }
            
            const data = getChartData(30);
            
            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.labels,
                    datasets: [{
                        label: 'Income',
                        data: data.income,
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        tension: 0.4,
                        fill: true
                    }, {
                        label: 'Expenses',
                        data: data.expenses,
                        borderColor: '#ef4444',
                        backgroundColor: 'rgba(239, 68, 68, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        }

        function getChartData(days) {
            const labels = [];
            const income = [];
            const expenses = [];
            
            for (let i = 6; i >= 0; i--) {
                const date = new Date();
                date.setDate(date.getDate() - (i * Math.floor(days / 7)));
                labels.push(date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
                
                income.push(Math.random() * 3000 + 500);
                expenses.push(Math.random() * 1500 + 200);
            }
            
            return { labels, income, expenses };
        }

        function updateChart() {
            initChart();
        }

        // Filter Functions
        function filterTransactions() {
            const account = document.getElementById('accountFilter').value;
            const days = document.getElementById('timeFilter').value;
            
            let filtered = currentUser.transactions;
            
            if (account !== 'all') {
                filtered = filtered.filter(t => t.account === account);
            }
            
            if (days !== 'all') {
                const cutoff = new Date();
                cutoff.setDate(cutoff.getDate() - parseInt(days));
                filtered = filtered.filter(t => new Date(t.date) >= cutoff);
            }
            
            // Re-render table
            const tableBody = document.getElementById('transactionsTable');
            tableBody.innerHTML = '';
            
            filtered.forEach(t => {
                const icon = getCategoryIcon(t.category);
                const colorClass = t.type === 'credit' ? 'text-green-600' : 'text-gray-900';
                const sign = t.type === 'credit' ? '+' : '-';
                
                tableBody.innerHTML += `
                    <tr class="hover:bg-gray-50 cursor-pointer">
                        <td class="px-4 py-3 text-sm">${formatDate(t.date)}</td>
                        <td class="px-4 py-3 font-medium">${t.description}</td>
                        <td class="px-4 py-3 text-sm"><span class="px-2 py-1 bg-gray-100 rounded-full text-xs">${t.category}</span></td>
                        <td class="px-4 py-3 text-sm capitalize">${t.account}</td>
                        <td class="px-4 py-3 text-right font-semibold ${colorClass}">${sign}${formatCurrency(t.amount)}</td>
                    </tr>
                `;
            });
        }

        function searchTransactions() {
            const term = document.getElementById('searchTransactions').value.toLowerCase();
            const rows = document.querySelectorAll('#transactionsTable tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        }

        // Utility Functions
        function showToast(message, type = 'info', duration = 3000) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            
            const colors = {
                success: 'bg-green-500',
                error: 'bg-red-500',
                warning: 'bg-yellow-500',
                info: 'bg-blue-600'
            };
            
            const icons = {
                success: 'fa-check-circle',
                error: 'fa-exclamation-circle',
                warning: 'fa-exclamation-triangle',
                info: 'fa-info-circle'
            };
            
            toast.className = `notification ${colors[type]} text-white px-6 py-3 rounded-lg shadow-lg flex items-center space-x-3 min-w-[300px]`;
            toast.innerHTML = `
                <i class="fas ${icons[type]}"></i>
                <span>${message}</span>
            `;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                toast.style.transition = 'all 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, duration);
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
        }

        function saveUser() {
            const users = JSON.parse(localStorage.getItem('fnb_users') || '[]');
            const index = users.findIndex(u => u.id === currentUser.id);
            
            if (index !== -1) {
                users[index] = currentUser;
                localStorage.setItem('fnb_users', JSON.stringify(users));
                localStorage.setItem('fnb_current_user', JSON.stringify(currentUser));
            }
        }

        function showNotifications() {
            showToast('You have no new notifications', 'info');
        }

        function showAccountDetails(account) {
            showSection('accounts');
            document.getElementById('accountFilter').value = account;
            filterTransactions();
        }

        function showTransactionDetail(id) {
            const t = currentUser.transactions.find(tr => tr.id === id);
            if (t) {
                showToast(`${t.description}: ${t.type === 'credit' ? '+' : '-'}${formatCurrency(t.amount)}`, 'info');
            }
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            const userMenu = document.getElementById('userMenu');
            const dropdown = document.getElementById('userDropdown');
            
            if (!userMenu.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
